# ---------------------------------------------------------------------------
# ARCTrack environment variables
# Copy this file to `.env` and fill in real values.
# ---------------------------------------------------------------------------

# Neon Postgres — use the POOLED connection string (host contains "-pooler").
# Prisma is configured for serverless; pooling avoids exhausting connections.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.us-east-2.aws.neon.tech/arctrack?sslmode=require"

# Vercel Blob store read/write token (Storage tab in the Vercel dashboard).
# Required for file/photo/logo uploads. Uploads are disabled locally without it.
BLOB_READ_WRITE_TOKEN=""

# Resend API key for transactional email.
# LEAVE BLANK IN DEV: emails are logged to the console instead of being sent.
RESEND_API_KEY=""

# The "from" address for outgoing email. Must be a Resend-verified domain in prod.
EMAIL_FROM="ARCTrack <notifications@example.com>"

# Secret used to sign committee session cookies. Any long random string.
# Generate: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
AUTH_SECRET="change-me-to-a-long-random-string"

# Shared secret for the reminder cron endpoint (/api/cron/reminders).
# Vercel Cron sends this as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET="change-me-to-a-long-random-string"

# Password used ONLY by the seed script to set each sample HOA's committee
# password. Real per-HOA passwords are set/rotated from the settings page.
SEED_COMMITTEE_PASSWORD="committee123"

# Public base URL (used in emails and generated letters). Optional in dev.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
